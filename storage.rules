rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Images produits : lecture publique, upload utilisateur connecté ──
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Photos galerie : lecture publique, upload utilisateur connecté ──
    match /photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Catégories : lecture publique, upload utilisateur connecté ──
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Tout le reste refusé ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
